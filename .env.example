# Google Maps API Key
# Get your API key from: https://console.cloud.google.com/google/maps-apis/
#
# IMPORTANT: For full auto-fill functionality, enable these APIs:
# 1. Go to Google Cloud Console
# 2. Create a new project or select existing one
# 3. Enable these APIs (click "Enable API"):
#    - Maps JavaScript API (required for map display)
#    - Places API (required for rating and photo auto-fill)
#    - Geocoding API (required for coordinate lookup)
# 4. Go to Credentials and create an API key
# 5. Copy the API key and paste it below

VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Supabase Configuration
# Get these from: https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
